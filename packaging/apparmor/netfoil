# man apparmor.d
abi <abi/4.0>,
include <tunables/global>

/usr/sbin/netfoil flags=(enforce) {
  # /etc/apparmor.d/abstractions/base
  include <abstractions/base>
  network inet tcp ip=1.1.1.2,
  network inet tcp ip=1.0.0.2,
  network inet udp peer=(ip=127.0.0.1),
 
  /etc/netfoil/* r,
  /etc/ssl/certs/ r,
  /etc/ssl/certs/* r,
  /usr/share/ca-certificates/mozilla/* r,

  deny /** x,

  # remove some of the defaults
  # TODO /proc, /sys, /etc
  deny ptrace,
  deny unix,

  deny /usr/lib** mrwlkx,

  deny /etc/ld.** mrwlkx,
  deny /etc/gcrypt/** mrwlkx,
  deny /etc/crypto-policies/** mrwlkx,
  deny /etc/gnutls/** mrwlkx,

  deny /dev/full mrwlkx,
  deny /dev/zero mrwlkx,

  deny /home/** mrwlkx,
  deny /root/** mrwlkx,

  deny /opt** mrwlkx,
}
